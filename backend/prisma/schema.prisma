generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model current_readings {
  device_id   Int            @id
  recorded_at DateTime       @db.Timestamp(6)
  pm1_0       Decimal        @db.Decimal(5, 2)
  pm2_5       Decimal        @db.Decimal(5, 2)
  pm10        Decimal        @db.Decimal(5, 2)
  temperature Decimal        @db.Decimal(5, 2)
  humidity    Decimal        @db.Decimal(5, 2)
  aqi         Int
  wifi_rssi   Int            @db.SmallInt
  pms_samples Int
  data_status reading_status @default(Valid)
  device      device         @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_current_device")
}

model device {
  device_id           Int                   @id @default(autoincrement())
  device_name         String                @db.VarChar(50)
  location_name       String                @db.VarChar(100)
  latitude            Decimal               @db.Decimal(9, 6)
  longitude           Decimal               @db.Decimal(9, 6)
  installed_date      DateTime              @db.Date
  status              device_status         @default(Pending)
  api_key             String?               @unique @db.VarChar(64)
  last_seen           DateTime?             @db.Timestamp(6)
  current_readings    current_readings?
  forecast_data       forecast_data[]
  historical_readings historical_readings[]
  predictions         predictions[]
}

model forecast_data {
  forecast_id               BigInt   @id @default(autoincrement())
  device_id                 Int
  forecast_generated_at     DateTime @db.Timestamp(6)
  forecast_for              DateTime @db.Timestamp(6)
  temperature               Decimal  @db.Decimal(5, 2)
  humidity                  Decimal  @db.Decimal(5, 2)
  wind_speed                Decimal  @db.Decimal(5, 2)
  wind_direction            Int      @db.SmallInt
  rainfall                  Decimal  @db.Decimal(5, 2)
  pressure                  Decimal  @db.Decimal(6, 2)
  weather_source            String   @db.VarChar(50)
  apparent_temperature      Decimal? @db.Decimal(5, 2)
  dew_point                 Decimal? @db.Decimal(5, 2)
  precipitation_probability Decimal? @db.Decimal(5, 2)
  wind_gusts                Decimal? @db.Decimal(5, 2)
  cloud_cover               Decimal? @db.Decimal(5, 2)
  visibility                Decimal? @db.Decimal(10, 2)
  uv_index                  Decimal? @db.Decimal(5, 2)
  boundary_layer_height     Decimal? @db.Decimal(10, 2)
  device                    device   @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_forecast_device")
}

model historical_readings {
  history_id  BigInt         @id @default(autoincrement())
  device_id   Int
  recorded_at DateTime       @db.Timestamp(6)
  pm1_0       Decimal        @db.Decimal(5, 2)
  pm2_5       Decimal        @db.Decimal(5, 2)
  pm10        Decimal        @db.Decimal(5, 2)
  temperature Decimal        @db.Decimal(5, 2)
  humidity    Decimal        @db.Decimal(5, 2)
  aqi         Int
  wifi_rssi   Int            @db.SmallInt
  pms_samples Int
  data_status reading_status @default(Valid)
  device      device         @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_history_device")

  @@index([device_id, recorded_at], map: "idx_history_device_time")
}

model predictions {
  prediction_id  BigInt   @id @default(autoincrement())
  device_id      Int
  predicted_at   DateTime @db.Timestamp(6)
  predicted_for  DateTime @db.Timestamp(6)
  pm1_0          Decimal  @db.Decimal(5, 2)
  pm2_5          Decimal  @db.Decimal(5, 2)
  pm10           Decimal  @db.Decimal(5, 2)
  temperature    Decimal  @db.Decimal(5, 2)
  humidity       Decimal  @db.Decimal(5, 2)
  aqi            Int
  risk_level     String?  @db.VarChar(50)
  reason         String?
  recommendation String?
  device         device   @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prediction_device")

  @@index([device_id, predicted_for], map: "idx_prediction_device_time")
}

enum device_status {
  Pending
  Active
  Deactive
}

enum reading_status {
  Valid
  Sensor_Error
  No_Data
}
