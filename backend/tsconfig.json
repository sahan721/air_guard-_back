{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "nodenext",
    "target": "esnext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "force",

    "skipLibCheck": true
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}